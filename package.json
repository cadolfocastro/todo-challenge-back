{
  "name": "todo-challenge-back",
  "version": "1.0.0",
  "description": "Todo Challenge Backend – Hexagonal Architecture with Firebase",
  "main": "dist/index.js",
  "engines": {
    "node": "20"
  },
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "jest",
    "test:coverage": "jest --coverage",
    "deploy": "npm run build && firebase deploy --only functions",
    "deploy:preview": "npm run build && firebase deploy --only functions --debug"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.2",
    "firebase-admin": "^12.7.0",
    "firebase-functions": "^7.1.1"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jest": "^30.0.0",
    "@types/node": "^22.10.0",
    "jest": "^30.3.0",
    "ts-jest": "^29.4.6",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.7.0"
  }
}
